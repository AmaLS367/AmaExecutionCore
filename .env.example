# ==========================================
# ⚙️ GENERAL SETTINGS
# ==========================================
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=DEBUG

# ==========================================
# 🏦 BYBIT API CREDENTIALS
# ==========================================
# Set to True to use Bybit Testnet, False for Mainnet
BYBIT_TESTNET=True

# Testnet credentials — used when BYBIT_TESTNET=True
BYBIT_TESTNET_API_KEY=your_bybit_testnet_api_key_here
BYBIT_TESTNET_API_SECRET=your_bybit_testnet_api_secret_here

# Mainnet credentials — used when BYBIT_TESTNET=False
BYBIT_API_KEY=your_bybit_mainnet_api_key_here
BYBIT_API_SECRET=your_bybit_mainnet_api_secret_here

# ==========================================
# 🗄️ DATABASE CONFIGURATION (PostgreSQL)
# ==========================================
# Make sure to use the postgresql+asyncpg driver for async operations
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tradingbot
REDIS_URL=redis://localhost:6379/0

# ==========================================
# 📈 TRADING ENGINE
# ==========================================
# Modes: shadow (no actual orders), demo (API testnet), real (API mainnet)
TRADING_MODE=shadow

# Modes: maker_only, maker_preferred, taker_allowed
# Scalping recommendation: keep maker_preferred unless your fee model justifies taker mode.
ORDER_MODE=maker_preferred
SHADOW_EQUITY=10000.0
USE_TRAILING_STOP=False
DEMO_CLOSE_TTL_SECONDS=30
DEMO_POLL_INTERVAL_SECONDS=1

# Required for e2e testnet run (tests/demo/test_testnet_flow.py).
# RRR must be >= MIN_RRR: (target - entry) / (entry - stop) >= 2.0
DEMO_TESTNET_SYMBOL=BTCUSDT
DEMO_TESTNET_ENTRY=95000.0
DEMO_TESTNET_STOP=94000.0
DEMO_TESTNET_TARGET=97000.0

# ==========================================
# 🔁 AUTONOMOUS SIGNAL LOOP (REST / DAY-TRADING)
# ==========================================
SIGNAL_LOOP_ENABLED=False
SIGNAL_LOOP_SYMBOLS=BTCUSDT,ETHUSDT
SIGNAL_LOOP_STRATEGY=rsi_ema
SIGNAL_LOOP_INTERVAL=15
SIGNAL_LOOP_COOLDOWN_SECONDS=300
SIGNAL_LOOP_MAX_SYMBOLS_CONCURRENT=5

# ==========================================
# Suggested day-trading overrides (15m-1h):
# ==========================================
# SIGNAL_LOOP_ENABLED=True
# SIGNAL_LOOP_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
# SIGNAL_LOOP_STRATEGY=rsi_ema
# SIGNAL_LOOP_INTERVAL=15
# RISK_PER_TRADE_PCT=0.005
# MIN_RRR=1.5
# MAX_OPEN_POSITIONS=2
# MAX_TOTAL_RISK_EXPOSURE_PCT=0.03
# MAX_TRADES_PER_DAY=10
# MAX_DAILY_LOSS_PCT=0.02
# HARD_PAUSE_CONSECUTIVE_LOSSES=4
# COOLDOWN_HOURS=2

# ==========================================
# ⚡ SCALPING (PUBLIC WS CANDLE FEED)
# ==========================================
SCALPING_ENABLED=False
SCALPING_SYMBOLS=BTCUSDT
SCALPING_INTERVAL=5
SCALPING_WS_WINDOW_SIZE=50
SCALPING_COOLDOWN_SECONDS=120

# ==========================================
# 💰 RISK MANAGEMENT
# ==========================================
RISK_PER_TRADE_PCT=0.01
MIN_RRR=2.0
MAX_OPEN_POSITIONS=1
MAX_TOTAL_RISK_EXPOSURE_PCT=0.03
MAX_TRADES_PER_DAY=10

# Suggested scalping overrides:
# RISK_PER_TRADE_PCT=0.003
# CANARY_MODE=True
# CANARY_RISK_MULTIPLIER=0.25
# MIN_RRR=1.5
# MAX_OPEN_POSITIONS=2
# MAX_TOTAL_RISK_EXPOSURE_PCT=0.01
# MAX_TRADES_PER_DAY=30

# Canary rollout guard for first production deploys.
CANARY_MODE=False
CANARY_RISK_MULTIPLIER=0.25

# ==========================================
# 🛡️ SAFETY GUARD
# ==========================================
MAX_DAILY_LOSS_PCT=0.03
MAX_WEEKLY_LOSS_PCT=0.05
MAX_CONSECUTIVE_LOSSES=3
HARD_PAUSE_CONSECUTIVE_LOSSES=5
COOLDOWN_HOURS=4

# Suggested scalping overrides:
# MAX_DAILY_LOSS_PCT=0.02
# MAX_CONSECUTIVE_LOSSES=4
# HARD_PAUSE_CONSECUTIVE_LOSSES=6
# COOLDOWN_HOURS=1

# ==========================================
# 🕒 MARKET DATA FRESHNESS
# ==========================================
MARKET_DATA_MAX_STALENESS_INTERVALS=2
MARKET_DATA_STALENESS_GRACE_SECONDS=15

# ==========================================
# 🔐 ADMIN PANEL
# ==========================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Or write it into .env automatically: python scripts/generate_admin_jwt_secret.py
ADMIN_JWT_SECRET=
ADMIN_JWT_ACCESS_TTL_MINUTES=30
ADMIN_JWT_REFRESH_TTL_DAYS=30
ADMIN_TOTP_ISSUER=AmaExecutionCore
ADMIN_CORS_ORIGIN=https://your-domain.com

# ==========================================
# 🌐 NGINX & DEPLOYMENT
# ==========================================
DOMAIN_NAME=your-domain.com
ADMIN_WHITELIST_IP=127.0.0.1
# Email for Let's Encrypt certificate notifications (optional, defaults to admin@DOMAIN_NAME)
CERTBOT_EMAIL=
