# ==========================================
# ⚙️ GENERAL SETTINGS
# ==========================================
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=DEBUG

# ==========================================
# 🏦 BYBIT API CREDENTIALS
# ==========================================
# Set to True to use Bybit Testnet, False for Mainnet
BYBIT_TESTNET=True

# Testnet credentials — used when BYBIT_TESTNET=True
BYBIT_TESTNET_API_KEY=your_bybit_testnet_api_key_here
BYBIT_TESTNET_API_SECRET=your_bybit_testnet_api_secret_here

# Mainnet credentials — used when BYBIT_TESTNET=False
BYBIT_API_KEY=your_bybit_mainnet_api_key_here
BYBIT_API_SECRET=your_bybit_mainnet_api_secret_here

# ==========================================
# 🗄️ DATABASE CONFIGURATION (PostgreSQL)
# ==========================================
# Make sure to use the postgresql+asyncpg driver for async operations
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tradingbot

# ==========================================
# 📈 TRADING ENGINE
# ==========================================
# Modes: shadow (no actual orders), demo (API testnet), real (API mainnet)
TRADING_MODE=shadow

# Modes: maker_only, maker_preferred, taker_allowed
ORDER_MODE=maker_preferred
SHADOW_EQUITY=10000.0
USE_TRAILING_STOP=False
DEMO_CLOSE_TTL_SECONDS=30
DEMO_POLL_INTERVAL_SECONDS=1

# Required for e2e testnet run (tests/demo/test_testnet_flow.py).
# RRR must be >= MIN_RRR: (target - entry) / (entry - stop) >= 2.0
DEMO_TESTNET_SYMBOL=BTCUSDT
DEMO_TESTNET_ENTRY=95000.0
DEMO_TESTNET_STOP=94000.0
DEMO_TESTNET_TARGET=97000.0

# ==========================================
# 💰 RISK MANAGEMENT
# ==========================================
RISK_PER_TRADE_PCT=0.01
MIN_RRR=2.0
MAX_OPEN_POSITIONS=1
MAX_TOTAL_RISK_EXPOSURE_PCT=0.03

# ==========================================
# 🛡️ SAFETY GUARD
# ==========================================
MAX_DAILY_LOSS_PCT=0.03
MAX_WEEKLY_LOSS_PCT=0.05
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_HOURS=4
